{
    "name": "react-reference-tracker",
    "version": "0.1.0",
    "description": "React dev tool for tracking prop/state reference changes and detecting unnecessary re-renders",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "postinstall": "rm -rf node_modules/react node_modules/react-dom node_modules/@types/react node_modules/@types/react-dom",
        "build": "tsup src/index.ts --format cjs,esm --dts && tsup src/babel/plugin.ts --format cjs --dts --out-dir dist/babel",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint",
        "prettier": "prettier --write"
    },
    "keywords": [
        "react",
        "reference",
        "tracker",
        "re-render",
        "performance",
        "devtool",
        "debug"
    ],
    "license": "MIT",
    "peerDependencies": {
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/types": "^7.29.0",
        "@eslint/js": "^9.39.4",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^18.0.0",
        "@types/react-dom": "^18.0.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^7.0.1",
        "jsdom": "^29.0.1",
        "prettier": "^3.8.1",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.58.0",
        "vitest": "^4.1.2"
    }
}
